{
  "name": "memora-app",
  "version": "1.0.0",
  "description": "",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev:ui": "npm --prefix ui run dev",
    "build:ui": "npm --prefix ui run build",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && electron .",
    "dev": "concurrently -k \"npm run dev:ui\" \"npm run dev:electron\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:ui && npm run build:electron"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bakko7821/memora-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/bakko7821/memora-app/issues"
  },
  "homepage": "https://github.com/bakko7821/memora-app#readme",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.0",
    "electron": "^38.0.0",
    "typescript": "^5.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "react-router": "^7.14.0",
    "tailwindcss": "^4.2.2"
  }
}
